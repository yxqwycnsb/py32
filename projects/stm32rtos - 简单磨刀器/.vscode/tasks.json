{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure",
      "type": "shell",
      "command": "cmake -S . -B build -DCMAKE_TOOLCHAIN_FILE=cmake/arm-none-eabi.toolchain.cmake -DLINKER_SCRIPT=Start/Project.sct",
      "problemMatcher": []
    },
    {
      "label": "CMake: Build",
      "type": "shell",
      "command": "cmake --build build --config Release -- -j",
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Flash: OpenOCD",
      "type": "shell",
      "command": "openocd -f interface/stlink.cfg -f target/stm32f1x.cfg -c \"program build/firmware.elf verify reset exit\"",
      "problemMatcher": [],
      "presentation": { "reveal": "always" }
    }
  ]
}